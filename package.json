{
  "name": "myoc",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run vendor:assets && tailwindcss -i ./src/styles/app.css -o ./public/app.css --minify",
    "vendor:assets": "node scripts/copy-vendor-assets.mjs",
    "dev": "npm run cf-typegen && npm run build && wrangler dev",
    "typecheck": "npm run cf-typegen && tsc --noEmit",
    "test": "vitest",
    "check": "npm run typecheck && vitest run",
    "db:migrate:local": "wrangler d1 migrations apply myoc-db --local",
    "db:seed:local": "wrangler d1 execute myoc-db --local --file seeds/development.sql",
    "db:prepare:local": "npm run db:migrate:local && npm run db:seed:local",
    "env:clone:prod-to-dev": "node scripts/clone-prod-to-dev.mjs",
    "env:clone:prod-to-dev:s3:dry-run": "npm run env:clone:prod-to-dev -- --dry-run --r2-mode=s3",
    "env:clone:prod-to-dev:s3:yes": "npm run env:clone:prod-to-dev -- --yes --r2-mode=s3",
    "deploy": "npm run check && npm run build && wrangler deploy --minify",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cropperjs": "^2.1.1",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}

{
  "name": "myoc",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler types && npm run build && wrangler dev",
    "build": "node scripts/copy-vendor-assets.mjs && tailwindcss -i ./src/styles/app.css -o ./public/app.css --minify",
    "typecheck": "wrangler types && tsc --noEmit",
    "lint": "biome ci .",
    "format": "biome format . --write",
    "deadcode": "knip",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "ci": "npm run lint && npm run typecheck && vitest run && npm run deadcode",
    "db:prepare:local": "wrangler d1 migrations apply myoc-db --local && wrangler d1 execute myoc-db --local --file seeds/development.sql",
    "env:clone:prod-to-dev": "node scripts/clone-prod-to-dev.mjs",
    "deploy": "npm run ci && npm run build && wrangler deploy --minify"
  },
  "dependencies": {
    "@scure/bip39": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "cropperjs": "^2.1.1",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@tailwindcss/cli": "^4.3.2",
    "@vitest/coverage-istanbul": "^4.1.10",
    "daisyui": "^5.6.14",
    "knip": "^6.26.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.108.0"
  }
}
